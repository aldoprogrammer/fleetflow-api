{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../src",
  "testRegex": ".*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": [
    "**/*.(t|j)s",
    "!**/*.module.ts",
    "!main.ts"
  ],
  "coverageDirectory": "../coverage/unit",
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^@fleetflow/shared$": "<rootDir>/../../fleetflow-shared/src/index.ts",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  }
}
