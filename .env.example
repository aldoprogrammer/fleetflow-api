NODE_ENV=development
PORT=3000

# Prisma Database Connection URL
DATABASE_URL="postgresql://fleetflow:fleetflow_local_secret@localhost:5432/fleetflow?schema=public"

# Authentication
JWT_SECRET=super_secret_fleetflow_jwt_key
JWT_EXPIRES_IN=7d

# BullMQ / Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379